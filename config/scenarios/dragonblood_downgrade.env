# Scenario: Dragonblood WPA3->WPA2 downgrade attack
# Note: --interface, --bssid, --output-dir are supplied by Makefile's run-attack target
HOSTAPD_CONF=/etc/hostapd/hostapd_sae_transition.conf
WPA_SUPPLICANT_CONF=/etc/wpa_supplicant/wpa_supplicant_sae.conf
ATTACK_CMD=downgrade-attack --duration 30
